pipeline {
    agent {
        node {
            label 'roboshop'
        }
    }
    environment {
        appName = ""
        appVersion = ""
        awsAccId = "381491827632"
        awsRegion = "us-east-1"
    }
    // parameters {
        // its useful in Build with Parameters in Jenkins
    // }
    options {
        timeout(time:10, unit:'MINUTES')
    }
    stages{
        stage ('ReadAppVersion') {
            steps {
                script {
                    // read JSON data from package.json
                    def data = readJSON file: 'package.json'

                    appName = data.name
                    appVersion = data.version

                    echo "ApplicationName: ${appName} Application Version:${appVersion}"

                    echo "Application ${appName} with AppVersion ${appVersion} will be deploy in aws account: ${awsAccId} region: ${awsRegion}"
                }
            }
        }
        // stage ('BuildImage') {
        //     steps {
        //         script {
        //             sh """


        //             """
        //         }
        //     }
        // }
    }
}