pipeline {
    agent {
        node {
            label 'roboshop'
        }
    }
    environment {
        awsAccId = "381491827632"
        awsRegion = "us-east-1"
        appName = ""
        appVersion = ""
    }
    options {
        // disableConcurrentBuilds()
        timeout(time:10, unit:"MINUTES")
    }
    stages {
        stage ('ReadApp Version') {
            steps {
                script {
                    def data = readJSON file:'package.json'

                    appName = data.name
                    appVersion = data.version

                    echo "Application Name: ${appName} Version:${appVersion}"

                    echo "Application hosting in aws account: ${env.awsAccId} and region is in ${env.awsRegion}" 
                }
            }
        }
        stage ('Dependencies Install') {
            steps {
                script {
                    sh """
                        npm install

                    """
                }
            }
        }
        stage ('Dependencies Test') {
            steps {
                // it works using Jest libraries tests
                script {
                    sh """
                        npm test

                    """
                }
            }
        }
        stage ('SonarQube Analysis') {
            steps {
                script{
                    def scannerHome = tool name: 'sonar-8'
                    withSonarQubeEnv('sonarqube-instance'){
                        sh """
                            echo "Performing SonarQube Analysis"
                            ${scannerHome}/bin/sonar-scanner
                        """
                    }
                }
            }
        }
        stage ('QualityGate Analysis') {
            steps {
                script {
                    timeout(time:5, unit:"MINUTES"){
                        waitForQualityGate abortPipeline: true
                    }
                }
            }
        }
        stage ('Dependabot Scan') {
            steps {
                withCredentials([string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')]) {
                    script {
                        def owner = "rkak87"
                        def repo = "${appName}"

                        def scanResultsJSON = sh (
                            script: """
                                curl -L \
                                -H "Accept: application/vnd.github+json" \
                                -H "Authorization: Bearer ${GITHUB_TOKEN}" \
                                -H "X-GitHub-Api-Version: 2022-11-28" \
                                https://api.github.com/repos/RKA87/catalogue/dependabot/alerts
                            """,
                            returnStdout: true
                        ).trim()

                        def scanResults = readJSON text: scanResultsJSON
                        def markdown_table = "| package | severity | ghsa_id | cve_id | summary |\n|---|---|---|---|\n"

                        if (scanResults.size() > 0) {
                            scanResults.each { alert ->
                            def pkg = alert.dependency.package
                            def severity = alert.security_advisory.severity
                            def ghsa_id = alert.security_advisory.ghsa_id
                            def cve_id = alert.security_advisory.cve_id
                            def summary = alert.security_advisory.summary

                            markdown_table += "| ${pkg} | ${severity} | ${ghsa_id} | ${cve_id} | ${summary} |\n|"
                            }
                        } else {
                            markdown_table += "| No open Dependabot alerts found! | | | |\n"
                        }
                        println(markdown_table)
                    }
                }
            }
        }            
        stage ('Build Image') {
            steps {
                script {
                    sh """
                    docker build -t ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion} .

                    """
                }
            }
        }
        stage ('Trivy Image Scan') {
            steps {
                script {
                    def scanResult = sh (
                        script: """
                            trivy image \
                                --scanners vuln \
                                --pkg-types os \
                                --severity HIGH,MEDIUM \
                                --format table \
                                --exit-code 1 \
                                --quiet \
                                ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion}
                    """,
                    returnStatus: true
                    )

                    if (scanResult !=0) {
                        error "🚨 Trivy found HIGH/MEDIUM misconfigurations in Dockerfile. Pipeline failed."
                        } else {
                        echo "✅ No HIGH or MEDIUM Dockerfile misconfigurations found. Pipeline continues."
                    }
                }
            }
        }
        stage ('Trivy Dockerfile Scan') {
            steps {
                script {
                    def imageScanResult = sh (
                        script: """
                            trivy config \
                            --severity HIGH,MEDIUM \
                            --exit-code 1 \
                            --format table \
                            Dockerfile
                    """,
                        returnStatus: true
                    )

                    if (imageScanResult !=0) {
                        error "🚨 Trivy found HIGH/MEDIUM misconfigurations in Dockerfile. Pipeline failed."
                        } else {
                        echo "✅ No HIGH or MEDIUM Dockerfile misconfigurations found. Pipeline continues."
                    }
                }
            }
        }
        stage ('Push Image to ECR') {
            steps {
                withAWS(credentials: 'aws-creds', region:"${env.awsRegion}") {
                    sh """
                        aws ecr get-login-password --region ${env.awsRegion} | docker login --username AWS --password-stdin ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com

                        docker push ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion}

                    """
                }
            }
        }
    }
    post {
        always {
            echo "pipeline final checks"
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
}