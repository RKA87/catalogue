pipeline {
    agent {
        node {
            label 'roboshop'
        }
    }
    environment {
        appName = ""
        appVersion = ""
        awsAccId = "381491827632"
        awsRegion = "us-east-1"
    }
    options{
        // disableConcurrentBuilds()
        timeout(time:10, unit:'MINUTES')
    }
    // parameters {
    //     // This stage will be useful to build with parameters in Jenkins
    // }
    stages {
        stage('ReadAppVersion') {
            steps {
                script {
                    def data = readJSON file: 'package.json'

                    appName = data.name
                    appVersion = data.version

                    echo "Application Name: ${appName} and Application Version: ${appVersion}"

                    echo "Copying the image process into aws account: ${env.awsAccId} region: ${env.awsRegion}"
                }
            }
        }
        stage('Sonarqube Analysis') {
            // tools {
            //     sonar 'sonar-8'
            // }
            steps {
                script {
                    def scannerHome = tool name: 'sonar-8'
                    withSonarQubeEnv('sonarqube-instance') {
                        sh """
                            echo "Performing Sonarqube scanning Analysis"
                            ${scannerHome}/bin/sonar-scanner

                        """
                    }
                }
            }
        }
        stage ('QualityGate Analysis') {
            steps {
                script {
                    timeout(time:5, unit:'MINUTES'){
                    waitForQualityGate abortPipeline: true
                    }
                }
            }
        }
        stage ('BuildImage') {
            steps {
                script {
                    withAWS(credentials: 'aws-creds', region: "${env.awsRegion}"){
                        sh """
                            aws ecr get-login-password --region ${env.awsRegion} | docker login --username AWS --password-stdin ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com
                            
                            docker build -t ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion} .

                            docker push ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion}

                        """
                    }
                }
            }
        }

    }
    post {
        always {
            echo "always perform final checks"
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
}