pipeline {
    agent {
        node {
            label 'roboshop'
        }
    }
    environment {
        appVersion = ""
        appName = ""
        aws_account_id = "381491827632"
        region = "us-east-1"
    }
    options {
        // disableConcurrentBuilds()
        timeout(time:10, unit: 'MINUTES')
    }
    // parameters {
    //     // name, type, default value and description
    // }
    stages {
        stage ('Read Package.json Version') {
            // when {
            //     expression { 
            //         "${params.Deploy}" == "true" 
            //     }
            // }
            steps {
                script {
                    // Load package.json and Parse it
                    def packageJson = readJSON file: 'package.json'
                    
                    appVersion = packageJson.version
                    appName = packageJson.name
                    echo "Building ${appName} version: ${appVersion}"
                } 
            }
        }
        stage ('Install Dependencies') {
            steps {
                script {
                    sh """
                        npm install
                    """
                }
            }
        }
        stage ('Image Build') {
            steps {
                script {
                    withAWS(credentials: 'aws-creds', region: "${region}") {
                        sh """
                            aws ecr get-login-password --region ${region} | docker login --username AWS --password-stdin ${aws_account_id}.dkr.ecr.us-east-1.amazonaws.com
                            
                            docker build -t ${aws_account_id}.dkr.ecr.${region}.amazonaws.com/roboshop/catalogue:${appVersion} .

                            docker push ${aws_account_id}.dkr.ecr.${region}.amazonaws.com/roboshop/catalogue:${appVersion}

                        """
                    }
                }
            }
        }
    }
    // post build checks 
    post {
        always {
            echo "Final Post Checks of ${appName} Deployment"
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
}