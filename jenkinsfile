pipeline {
    agent {
        node {
            label 'roboshop'
        }
    }
    environment {
        awsAccID = "381491827632"
        awsRegion = "us-east-1"
        appName = ""
        appVersion = ""
    }
    options {
        // disableConcurrentBuilds()
        timeout(time:10, unit:"MINUTES")
    }
    // paramters {
    // This section is using for Jenkins Build with Parameter section

    // }
    stages {
        stage ('ReadAppVersion') {
            steps {
                script {
                    def data = readJSON file: 'package.json'
                    appName = data.name
                    appVersion = data.version

                    echo "Application Name: ${appName} Version: ${appVersion}"
                    echo "Application is hosted in aws account ${env.awsAccID} region ${env.awsRegion}"

                }
            }
        }
        stage ('SonarQube Analysis') {
            steps {
                script {
                    def scannerHome = tool name: 'sonar-8'

                    withSonarQubeEnv('sonarqube-instance') {
                        sh """
                            echo "performing sonarqube analysis"
                            ${scannerHome}/bin/sonar-scanner

                        """
                    }

                }
            }
        }
        stage ('QualityGate Analaysis') {
            steps {
                script {
                    timeout(time:5, unit:'MINUTES') {
                    waitForQualityGate abortPipeline: true
                    }
                }
            }
        }
        stage ('BuildImage') {
            steps {
                script {
                    withAWS(credentials: 'aws-creds', region: "${env.awsRegion}") {
                        sh """
                            echo "scans completed image build process initiated"

                            aws ecr get-login-password --region ${env.awsRegion} | docker login --username AWS --password-stdin ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com

                            docker build -t ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion} .

                            docker push  ${env.awsAccId}.dkr.ecr.${env.awsRegion}.amazonaws.com/roboshop/${appName}:${appVersion}

                        """
                    }

                }
            }
        }
    }
    post {
        always {
            echo "perform finalchecks always"
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
}