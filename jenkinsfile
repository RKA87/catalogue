pipeline {
    agent {
        node {
            label 'roboshop'
        }
    }
    environment {
        appName = ""
        appVersion = ""
        awsAccId = "381491827632"
        awsRegion = "us-east-1"
    }
    // parameters {
        // its useful in Build with Parameters in Jenkins
    // }
    options {
        timeout(time:10, unit:'MINUTES')
    }
    stages{
        stage ('ReadAppVersion') {
            steps {
                script {
                    // read JSON data from package.json
                    def data = readJSON file: 'package.json'

                    appName = data.name
                    appVersion = data.version

                    echo "ApplicationName: ${appName} Application Version:${appVersion}"

                    echo "Application ${appName} with AppVersion ${appVersion} will be deploy in aws account: ${env.awsAccId} region: ${env.awsRegion}"
                }
            }
        }
        stage ('BuildImage') {
            steps {
                script {
                    withAWS(credentials: 'aws-creds', region: "${env.awsRegion}") {
                    
                    sh """
                        aws ecr get-login-password --region ${env.awsRegion} | docker login --username AWS --password-stdin ${awsAccId}.dkr.ecr.us-east-1.amazonaws.com

                        docker build -t roboshop/${appName}:${appVersion} .

                        docker push ${awsAccId}.dkr.ecr.us-east-1.amazonaws.com/roboshop/${appName}:${appVersion}
                    """
                    }
                }
            }
        }
    }
    post {
        always {
            echo "perform final checks always after build"
        }
        success {
            echo "pipeline success"
        }
        failure {
            echo "pipeline failure"
        }
    }
}